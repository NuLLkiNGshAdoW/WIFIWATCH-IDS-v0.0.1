<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
     <!-- Define NOSNIFF to exclude native packet capture code when packages/drivers are unavailable -->
		<DefineConstants>NOSNIFF</DefineConstants>
		<UseWindowsForms>true</UseWindowsForms>
		<ImplicitUsings>enable</ImplicitUsings>
		<SupportedOSPlatformVersion>7.0</SupportedOSPlatformVersion>
	</PropertyGroup>
	<ItemGroup>
	  <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
	  <PackageReference Include="System.Text.Encoding.CodePages" Version="10.0.5" />
      <PackageReference Include="SharpPcap" Version="5.1.0" />
	  <PackageReference Include="PacketDotNet" Version="1.0.3" />
	</ItemGroup>
</Project>